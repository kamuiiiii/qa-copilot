{
  "extraKnownMarketplaces": {
    "qa-tools": { "source": { "source": "github", "repo": "kamuiiiii/qa-copilot-plugin" } }
  },
  "enabledPlugins": { "qa-copilot@qa-tools": true },
  "permissions": {
    "allow": [
      "Bash(browser-use:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(date:*)",
      "Bash(open:*)",
      "Read",
      "Write",
      "Edit"
    ]
  }
}
